async function sendToSheet(action, data) {
  if (APPS_SCRIPT_URL === 'YOUR_APPS_SCRIPT_URL_HERE') {
    console.log('[Apps Script] Not configured yet. Would send:', action, data);
    return { ok: true };
  }
  try {
    const res = await fetch(APPS_SCRIPT_URL, {
      method: 'POST',
      body: JSON.stringify({ action, ...data }),
    });
    return await res.json();
  } catch(e) {
    console.error('Apps Script error:', e);
    throw e;
  }
}

async function saveAporte() {
  const data  = document.getElementById('aporteData').value;
  const valor = parseFloat(document.getElementById('aporteValor').value);
  const origem = document.getElementById('aporteOrigem').value;
  const destino = document.getElementById('aporteDestino').value;

  if (!data || !valor) { toast('Preencha data e valor', 'error'); return; }

  try {
    await sendToSheet('append_aporte', { data, valor, origem, destino });
    // Optimistic update
    state.aportes.push({ DATA: data, APORTE: valor, Origem: origem, Destino: destino });
    renderAportes();
    renderKPIs();
    closeModal('modalAporte');
    document.getElementById('aporteData').value = '';
    document.getElementById('aporteValor').value = '';
    document.getElementById('aporteOrigem').value = '';
    document.getElementById('aporteDestino').value = '';
    toast('Aporte salvo com sucesso!');
  } catch(e) {
    toast('Erro ao salvar aporte', 'error');
  }
}

async function saveResgate() {
  const data  = document.getElementById('resgateData').value;
  const valor = parseFloat(document.getElementById('resgateValor').value);
  const origem = document.getElementById('resgateOrigem').value;
  const motivo = document.getElementById('resgateMotivo').value;

  if (!data || !valor) { toast('Preencha data e valor', 'error'); return; }

  try {
    await sendToSheet('append_resgate', { data, valor, origem, motivo });
    state.resgates.push({ Data: data, Valor: valor, Origem: origem, Motivo: motivo });
    renderResgates();
    closeModal('modalResgate');
    toast('Resgate salvo com sucesso!');
  } catch(e) {
    toast('Erro ao salvar resgate', 'error');
  }
}

async function saveGasto() {
  const data       = document.getElementById('gastoData').value;
  const nome       = document.getElementById('gastoNome').value;
  const valor      = parseFloat(document.getElementById('gastoValor').value);
  const pagamento  = document.getElementById('gastoPagamento').value;
  const categoria  = document.getElementById('gastoCategoria').value;

  if (!data || !nome || !valor) { toast('Preencha todos os campos', 'error'); return; }

  try {
    await sendToSheet('append_gasto', { data, nome, valor, pagamento, categoria });
    state.gastosPessoais.push({ Data: data, Nome: nome, Valor: valor, 'Forma de pagamento': pagamento, Categoria: categoria });
    renderGastos();
    closeModal('modalGasto');
    document.getElementById('gastoNome').value = '';
    document.getElementById('gastoValor').value = '';
    toast('Gasto registrado!');
  } catch(e) {
    toast('Erro ao salvar gasto', 'error');
  }
}

