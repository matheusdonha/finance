function csvUrl(gid) {
  return `https://docs.google.com/spreadsheets/d/e/${PUBLISHED_ID}/pub?gid=${gid}&single=true&output=csv`;
}

async function fetchCSV(gid) {
  try {
    const res = await fetch(csvUrl(gid));
    const text = await res.text();
    return parseCSV(text);
  } catch(e) {
    console.warn('Failed to fetch GID', gid, e);
    return [];
  }
}

function parseCSV(text) {
  const lines = text.trim().split('\n');
  if (lines.length < 2) return [];
  const headers = lines[0].split(',').map(h => h.trim().replace(/^"|"$/g,''));
  return lines.slice(1).map(line => {
    const vals = splitCSVLine(line);
    const obj = {};
    headers.forEach((h,i) => { obj[h] = (vals[i] || '').trim().replace(/^"|"$/g,''); });
    return obj;
  });
}

function splitCSVLine(line) {
  const result = [];
  let cur = '', inQuote = false;
  for (let i = 0; i < line.length; i++) {
    const ch = line[i];
    if (ch === '"') { inQuote = !inQuote; continue; }
    if (ch === ',' && !inQuote) { result.push(cur); cur = ''; continue; }
    cur += ch;
  }
  result.push(cur);
  return result;
}

function fmtBRL(val) {
  const n = parseFloat(val) || 0;
  return n.toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}

function fmtDate(serial) {
  // Excel serial date to JS date
  const n = parseFloat(serial);
  if (isNaN(n)) return serial || '—';
  const d = new Date(Math.round((n - 25569) * 86400 * 1000));
  return d.toLocaleDateString('pt-BR');
}

function serialToDate(serial) {
  const n = parseFloat(serial);
  if (isNaN(n)) return null;
  return new Date(Math.round((n - 25569) * 86400 * 1000));
}

function getMonthLabel(serial) {
  const d = serialToDate(serial);
  if (!d) return '—';
  return d.toLocaleDateString('pt-BR', { month: 'short', year: '2-digit' });
}

