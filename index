function doPost(e) {
  const data = JSON.parse(e.postData.contents);
  const ss = SpreadsheetApp.getActiveSpreadsheet();

  if (data.action === 'append_aporte') {
    const sheet = ss.getSheetByName('aportes');
    const lastRow = sheet.getLastRow();
    const totalAportado = sheet.getRange(lastRow, 4).getValue() || 0;
    sheet.appendRow([
      data.data,
      data.valor,
      '',
      totalAportado + data.valor,
      data.origem || '',
      data.destino || ''
    ]);
  }

  if (data.action === 'append_resgate') {
    const sheet = ss.getSheetByName('resgastes');
    sheet.appendRow([data.data, data.valor, data.motivo, data.origem || '']);
  }

  if (data.action === 'append_gasto') {
    const sheet = ss.getSheetByName('gastos_pessoais');
    sheet.appendRow([data.data, data.nome, data.valor, data.pagamento, data.categoria]);
  }

  if (data.action === 'meta') {
    const sheet = ss.getSheetByName('aportes');
    // Salva a meta na célula G2 (coluna extra que você criou)
    sheet.getRange('G2').setValue(data.meta);
  }

  return ContentService
    .createTextOutput(JSON.stringify({ status: 'ok' }))
    .setMimeType(ContentService.MimeType.JSON);
}

