// KPIs
// ══════════════════════════════════════════════════════════════════
function renderKPIs() {
  const ali = state.alinhamento;
  if (!ali.length) return;

  const last = ali[ali.length - 1];
  const prev = ali[ali.length - 2];
  const totalAtual = parseFloat(last['Todos']) || 0;
  const totalPrev  = parseFloat(prev?.['Todos']) || 0;
  const delta = totalAtual - totalPrev;
  const deltaPct = totalPrev ? ((delta / totalPrev) * 100).toFixed(1) : 0;

  // Total aportado do ano
  const totalAportado = state.aportes.reduce((s, r) => s + (parseFloat(r['APORTE']) || 0), 0);

  // Entradas do último mês com dados
  const lastDate = serialToDate(last['Mês']);
  const lastMonth = lastDate ? lastDate.getMonth() : -1;
  const entradaMes = state.mesMes[lastMonth]?.entradaProj || 0;

  const grid = document.getElementById('kpiGrid');
  grid.innerHTML = `
    <div class="kpi-card" style="--accent-color:var(--green)">
      <div class="kpi-label">Patrimônio Atual</div>
      <div class="kpi-value"><span class="currency">R$</span> ${fmtBRL(totalAtual)}</div>
      <div class="kpi-delta ${delta >= 0 ? 'up':'down'}">
        ${delta >= 0 ? '↑':'↓'} R$ ${fmtBRL(Math.abs(delta))} (${deltaPct}%) vs anterior
      </div>
    </div>
    <div class="kpi-card" style="--accent-color:var(--blue)">
      <div class="kpi-label">Total Aportado 2026</div>
      <div class="kpi-value"><span class="currency">R$</span> ${fmtBRL(totalAportado)}</div>
      <div class="kpi-delta">${state.aportes.length} aportes registrados</div>
    </div>
    <div class="kpi-card" style="--accent-color:var(--gold)">
      <div class="kpi-label">Meta de Aportes</div>
      <div class="kpi-value"><span class="currency">R$</span> ${fmtBRL(state.meta)}</div>
      <div class="kpi-delta ${totalAportado >= state.meta ? 'up':''}">
        ${((totalAportado/state.meta)*100).toFixed(1)}% atingido
      </div>
    </div>
    <div class="kpi-card" style="--accent-color:var(--purple)">
      <div class="kpi-label">Meta Patrimônio Dez/26</div>
      <div class="kpi-value"><span class="currency">R$</span> ${fmtBRL(78794.46)}</div>
      <div class="kpi-delta">Projeção anual</div>
    </div>
  `;
}

