// ══════════════════════════════════════════════════════════════════
// DATA LOADING
// ══════════════════════════════════════════════════════════════════
async function loadAllData() {
  const btn = document.querySelector('#refreshBtn .btn');
  btn.classList.add('loading');
  btn.disabled = true;

  try {
    const [alinhCSV, aporteCSV, resgateCSV, gastosCSV] = await Promise.all([
      fetchCSV(SHEET_GIDS.alinhamento),
      fetchCSV(SHEET_GIDS.aportes),
      fetchCSV(SHEET_GIDS.resgates),
      fetchCSV(SHEET_GIDS.gastos_pessoais),
    ]);

    state.alinhamento = alinhCSV.filter(r => r['Mês'] && r['Todos']);
    state.aportes = aporteCSV.filter(r => r['DATA'] && r['APORTE'] && parseFloat(r['APORTE']) > 0);
    state.resgates = resgateCSV.filter(r => r['Data'] && r['Valor'] && parseFloat(r['Valor']) > 0);
    state.gastosPessoais = gastosCSV.filter(r => r['Data'] && r['Valor']);

    // Extract meta from aportes sheet if present
    const metaRow = aporteCSV.find(r => r['META'] || r['Meta'] || r['meta']);
    if (metaRow) {
      const metaVal = parseFloat(metaRow['META'] || metaRow['Meta'] || metaRow['meta']);
      if (!isNaN(metaVal) && metaVal > 0) state.meta = metaVal;
    }

    // Mock mes a mes from what we know (will be replaced by real CSV)
    state.mesMes = buildMesMes();

    // Render all sections
    renderKPIs();
    renderOverviewChart();
    renderGanhoChart();
    renderOverviewTable();
    renderEvolucao();
    renderProjecao();
    renderAportes();
    renderResgates();
    renderGastos();

    document.getElementById('lastUpdateTime').textContent = new Date().toLocaleTimeString('pt-BR', {hour:'2-digit',minute:'2-digit'});
    toast('Dados atualizados com sucesso');
  } catch(e) {
    console.error(e);
    toast('Erro ao carregar dados', 'error');
  } finally {
    btn.classList.remove('loading');
    btn.disabled = false;
  }
}

