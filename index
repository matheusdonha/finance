function renderGastosTable(filter = '') {
  const gp = state.gastosPessoais;
  const total = gp.reduce((s,r) => s + (parseFloat(r['Valor'])||0), 0);

  // Este mês
  const now = new Date();
  const mesMes = gp.filter(r => {
    const d = new Date(r['Data']);
    return d.getMonth() === now.getMonth() && d.getFullYear() === now.getFullYear();
  });
  const totalMes = mesMes.reduce((s,r) => s + (parseFloat(r['Valor'])||0), 0);

  document.getElementById('totalGastos').textContent = fmtBRL(total);
  document.getElementById('gastosMes').textContent   = fmtBRL(totalMes);
  document.getElementById('qtdGastos').textContent   = gp.length;

  const body = document.getElementById('gastosTableBody');
  const filtered = filter
    ? gp.filter(r => (r['Nome']||'').toLowerCase().includes(filter.toLowerCase()) ||
                      (r['Categoria']||'').toLowerCase().includes(filter.toLowerCase()))
    : gp;

  if (!filtered.length) {
    body.innerHTML = '<tr><td colspan="5"><div class="empty-state"><div class="empty-icon">◎</div><div class="empty-text">Nenhum gasto registrado ainda.<br>Use o botão "+ Registrar Gasto" para começar.</div></div></td></tr>';
    return;
  }

  body.innerHTML = [...filtered].reverse().map(r => {
    const catColors = {
      'Alimentação':'badge-green','Transporte':'badge-blue','Lazer':'badge-purple',
      'Saúde':'badge-red','Roupas':'badge-gold','Presentes':'badge-gold',
      'Educação':'badge-blue','Outro':'badge-muted'
    };
    const catClass = catColors[r['Categoria']] || 'badge-muted';
    return `<tr>
      <td class="nowrap">${r['Data'] || '—'}</td>
      <td>${r['Nome'] || '—'}</td>
      <td class="text-red"><strong>R$ ${fmtBRL(r['Valor'])}</strong></td>
      <td><span class="badge badge-muted">${r['Forma de pagamento'] || '—'}</span></td>
      <td><span class="badge ${catClass}">${r['Categoria'] || '—'}</span></td>
    </tr>`;
  }).join('');
}

function renderGastosCharts() {
  destroyChart('gastosPie');
  destroyChart('gastosMes');

  const gp = state.gastosPessoais;
  if (!gp.length) return;

  // By category
  const byCat = {};
  gp.forEach(r => {
    const cat = r['Categoria'] || 'Outro';
    byCat[cat] = (byCat[cat] || 0) + (parseFloat(r['Valor']) || 0);
  });

  const catColors = ['#4F8EF7','#00E5A0','#FFB547','#FF4D6D','#A78BFA','#00D4E5','#81C784','#F7DC6F'];
  const ctx1 = document.getElementById('gastosChart').getContext('2d');
  state.charts.gastosPie = new Chart(ctx1, {
    type: 'doughnut',
    data: {
      labels: Object.keys(byCat),
      datasets: [{ data: Object.values(byCat), backgroundColor: catColors, borderWidth: 0, hoverOffset: 6 }]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { ...CHART_DEFAULTS.plugins, legend: { position: 'right', labels: { color: '#8892B0', font: { family: 'DM Mono', size: 10 }, boxWidth: 8 } } },
      cutout: '70%'
    }
  });

  // By month
  const byMes = {};
  gp.forEach(r => {
    let label = r['Data'] || '';
    try {
      const d = new Date(r['Data']);
      label = d.toLocaleDateString('pt-BR', { month: 'short' });
    } catch(e){}
    byMes[label] = (byMes[label] || 0) + (parseFloat(r['Valor']) || 0);
  });

  const ctx2 = document.getElementById('gastosMesChart').getContext('2d');
  state.charts.gastosMes = new Chart(ctx2, {
    type: 'bar',
    data: {
      labels: Object.keys(byMes),
      datasets: [{
        label: 'Gastos', data: Object.values(byMes),
        backgroundColor: '#FF4D6D55', borderColor: '#FF4D6D', borderWidth: 1, borderRadius: 4,
      }]
    },
    options: CHART_DEFAULTS
  });
}

function filterGastos() {
  const q = document.getElementById('gastosSearch').value;
  renderGastosTable(q);
}

