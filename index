function renderAportes() {
  const ap = state.aportes;
  const total = ap.reduce((s,r) => s + (parseFloat(r['APORTE'])||0), 0);
  const falta = Math.max(0, state.meta - total);
  const pct = Math.min(100, state.meta > 0 ? (total/state.meta*100) : 0);

  document.getElementById('totalAportado').textContent = 'R$ ' + fmtBRL(total);
  document.getElementById('faltaAportar').textContent  = 'R$ ' + fmtBRL(falta);
  document.getElementById('progressPct').textContent   = pct.toFixed(1) + '%';
  document.getElementById('progressFill').style.width  = pct + '%';
  document.getElementById('aporteCount').textContent   = ap.length + ' aportes';

  // Meta editável
  const metaDisplay = document.getElementById('metaValDisplay');
  metaDisplay.innerHTML = `<span class="editable" contenteditable="true"
    onblur="saveMeta(this)" onkeydown="if(event.key==='Enter'){this.blur()}"
    title="Clique para editar">R$ ${fmtBRL(state.meta)}</span>`;
  document.getElementById('progressMeta').textContent = 'Meta: R$ ' + fmtBRL(state.meta);

  const body = document.getElementById('aporteTableBody');
  if (!ap.length) {
    body.innerHTML = '<tr><td colspan="5"><div class="empty-state"><div class="empty-icon">⊕</div><div class="empty-text">Nenhum aporte registrado</div></div></td></tr>';
    return;
  }

  let acum = 0;
  body.innerHTML = [...ap].reverse().map(r => {
    acum += parseFloat(r['APORTE']) || 0;
    return `<tr>
      <td class="nowrap">${fmtDate(r['DATA'])}</td>
      <td class="text-green"><strong>R$ ${fmtBRL(r['APORTE'])}</strong></td>
      <td class="text-muted">${r['Origem'] || '—'}</td>
      <td class="text-muted">${r['Destino'] || '—'}</td>
      <td>R$ ${fmtBRL(acum)}</td>
    </tr>`;
  }).join('');
}

function saveMeta(el) {
  const raw = el.textContent.replace(/[^0-9,.]/g,'').replace(',','.');
  const val = parseFloat(raw);
  if (!isNaN(val) && val > 0) {
    state.meta = val;
    el.textContent = 'R$ ' + fmtBRL(val);
    renderAportes();
    toast('Meta atualizada');
    // send to Apps Script
    sendToSheet('meta', { meta: val });
  }
}

